# Primary AI model
GOOGLE_API_KEY=your_gemini_key_here

# ElasticSearch
ES_URL=your_elastic_serverless_url_here
ES_API_KEY=your_elastic_api_key_here
ES_INDEX_NAME=brandpulse-content

# Redis (Upstash)
UPSTASH_REDIS_URL=your_upstash_url_here
UPSTASH_REDIS_TOKEN=your_upstash_token_here

# Postgres (Neon)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Data sources
NEWSAPI_KEY=your_newsapi_key_here
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=brandpulse-ai/0.1 by yourusername

# LangSmith observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=brandpulse-ai
